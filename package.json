{
	"name": "generic-aes70",
	"version": "0.2.1",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-generic-aes70.git"
	},
	"engines": {
		"node": "^26.4",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "~2.1.0",
		"aes70": "^2.0.19",
		"es-toolkit": "^1.49.0",
		"ws": "^8.21.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.2",
		"@types/node": "^26.0.1",
		"@types/ws": "^8.18.1",
		"eslint": "^10.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.0",
		"rimraf": "^6.1.3",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.62.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.17.0"
}
